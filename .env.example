# runnerCLI
# Command nay khong co env rieng. No chi dieu huong sang 1 trong 3 CLI ben duoi.

# ==================================================
# Block: runnerCLI-createtunnel
# Purpose: tao Cloudflare tunnel + DNS routes

CLOUDFLARED_TUNNEL_NAME=my-app
CLOUDFLARED_TUNNEL_DOMAIN_00=app.example.com
CLOUDFLARED_TUNNEL_DOMAIN_01=ssh-app.example.com
SSH_PORT=2222
CLOUDFLARED_DEFAULT_SERVICE=http://127.0.0.1:80

# Optional: them noi tim credentials/config cua cloudflared
# CLOUDFLARED_HOME=
# CLOUDFLARED_CONFIG=

# ==================================================
# Block: runnerCLI-tailscale
# Purpose: update Tailscale ACL qua API

TAILSCALE_CLIENT_ID=ts-client-id
TAILSCALE_CLIENT_SECRET=ts-client-secret
TAILSCALE_TAILNET=-
TAILSCALE_ACL_BODY_FILE=./tailscale/access-controls.hujson
TAILSCALE_API_BASE_URL=https://api.tailscale.com
TAILSCALE_API_TIMEOUT_MS=30000

# Optional
# TAILSCALE_OAUTH_SCOPE=

# ==================================================
# Block: runnerCLI-patch-env
# Purpose: patch gia tri *_BASE64 trong mot file .env dich
#
# Ghi chu:
# - Cac dong ben duoi la noi dung mau cho file .env can duoc patch.
# - Thuong ban se copy block nay vao file .env thuc te cua app dich.
# - runnerCLI-patch-env se doc comment "# Path:" va ghi base64 vao key ngay sau do.

# Path: ./cloudflared-credentials.json
CLOUDFLARED_CREDENTIALS_JSON_BASE64=

# Path: ./cloudflared-config.yml
CLOUDFLARED_CONFIG_YML_BASE64=
